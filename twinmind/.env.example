# Azure OpenAI Configuration
REACT_APP_AZURE_OPENAI_ENDPOINT="https://your-resource-name.openai.azure.com/"
REACT_APP_AZURE_OPENAI_KEY="your-azure-openai-api-key"
REACT_APP_AZURE_DEPLOYMENT_NAME="your-deployment-name"

# Azure AI Search Configuration (for OneDrive/Sharepoint indexed documents)
REACT_APP_AZURE_SEARCH_ENDPOINT="https://your-search-service.search.windows.net"
REACT_APP_AZURE_SEARCH_KEY="your-azure-search-admin-key"
REACT_APP_AZURE_SEARCH_INDEX="your-index-name"

# MSAL Configuration
VITE_MSAL_CLIENT_ID="your-client-id-here"
VITE_MSAL_TENANT_ID="your-tenant-id-here"
